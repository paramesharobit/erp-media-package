{
    "version": "1.0.0",
    "name": "arobit/erp-media",
    "description": "Laravel media management package for ERP workflows.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "media",
        "erp",
        "uuid",
        "api"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.20",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Arobit\\ErpMedia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arobit\\ErpMedia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arobit\\ErpMedia\\ErpMediaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
